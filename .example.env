 DATABASE_URL=postgres://postgres:postgres@localhost/csc_core
 STATS_API_URL=http://localhost:4000
 REQUEST_ROOT_DIR=/demos - will override root directory of demo, can use to match a mapped dir in docker

# Historical round-player-stat backfill
STATS_REPAIR_TOKEN=replace-with-the-same-secret-configured-in-csc-stats
STATS_REPAIR_PARSER_VERSION=worker-vX-demoScrape-vY@sha256:image-digest
# --workspace on the host must map to this path in the CSC-Stats container.
STATS_REPAIR_API_PATH_ROOT=/demos/round-repair-work
